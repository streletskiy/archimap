# =========================
# Server / Runtime
# =========================
# PORT=3252
# HOST=0.0.0.0
TRUST_PROXY=true
LOG_LEVEL=warn
METRICS_ENABLED=false

# =========================
# Security / Sessions
# =========================
SESSION_SECRET=change-me
# APP_BASE_URL=https://archimap.example.com
# APP_SETTINGS_SECRET=change-me
# REDIS_URL=redis://redis:6379
# SESSION_ALLOW_MEMORY_FALLBACK=true
# CSP_CONNECT_SRC_EXTRA=https://tiles.basemaps.cartocdn.com,https://*.basemaps.cartocdn.com
# Session cookie `Secure` flag override:
# - true  : production behind HTTPS
# - false : local Docker/http:// (otherwise browser drops cookie and session looks "logged out")
# SESSION_COOKIE_SECURE=true

# =========================
# Database Paths
# =========================
DB_PROVIDER=postgres
# For local dev with SQLite:
# DB_PROVIDER=sqlite
DATABASE_URL=postgresql://archimap:archimap@db-postgres:5432/archimap
# SQLITE_URL=data/sqlite/archimap.db
# DATABASE_PATH=data/sqlite/archimap.db
# ARCHIMAP_DB_PATH=data/sqlite/archimap.db
# OSM_DB_PATH=data/sqlite/osm.db
# LOCAL_EDITS_DB_PATH=data/sqlite/local-edits.db
# USER_EDITS_DB_PATH=data/sqlite/user-edits.db
# USER_AUTH_DB_PATH=data/sqlite/users.db

# PostgreSQL / PostGIS (used when DB_PROVIDER=postgres)
# POSTGRES_HOST=db-postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=archimap
# POSTGRES_USER=archimap
# POSTGRES_PASSWORD=archimap

# =========================
# App Behavior
# =========================
# APP_DISPLAY_NAME=archimap
# MAP_DEFAULT_LON=44.0059
# MAP_DEFAULT_LAT=56.3269
# MAP_DEFAULT_ZOOM=15
# USER_EDIT_REQUIRES_PERMISSION=true

# Registration / Password reset limits
# REGISTRATION_ENABLED=true
# REGISTRATION_CODE_TTL_MINUTES=15
# REGISTRATION_CODE_RESEND_COOLDOWN_SEC=60
# REGISTRATION_CODE_MAX_ATTEMPTS=6
# REGISTRATION_MIN_PASSWORD_LENGTH=8
# PASSWORD_RESET_TTL_MINUTES=60

# =========================
# Email / SMTP
# =========================
# SMTP_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# =========================
# OSM Import Source
# =========================
# Choose one source:
# 1) Extract query / queries
#    OSM_EXTRACT_QUERY=Gibraltar
#    OSM_EXTRACT_QUERIES=Nizhny Novgorod;Moscow Oblast;Russia
# 2) Local PBF file
#    OSM_PBF_PATH=/absolute/path/to/file.osm.pbf
OSM_EXTRACT_QUERIES=Nizhny Novgorod
# OSM_PBF_PATH=

# Importer progress
# PBF_PROGRESS_EVERY=10000
# PBF_PROGRESS_COUNT_PASS=true

# =========================
# Auto Sync / PMTiles
# =========================
# AUTO_SYNC_ENABLED=true
# AUTO_SYNC_ON_START=false
# AUTO_SYNC_INTERVAL_HOURS=168
# BUILDINGS_PMTILES_FILE=buildings.pmtiles
# BUILDINGS_PMTILES_SOURCE_LAYER=buildings
# BUILDINGS_PMTILES_MIN_ZOOM=13
# BUILDINGS_PMTILES_MAX_ZOOM=16
# MAP_SELECTION_ATOMIC_DEBUG=false

# =========================
# Tippecanoe
# =========================
# TIPPECANOE_BIN=/absolute/path/to/tippecanoe
# TIPPECANOE_PROGRESS_JSON=true
# TIPPECANOE_PROGRESS_INTERVAL_SEC=5
