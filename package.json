{
  "name": "archimap",
  "version": "1.0.0",
  "main": "server.ts",
  "scripts": {
    "predev": "node --import tsx scripts/generate-version.ts",
    "prebuild": "node --import tsx scripts/generate-version.ts",
    "prestart": "node --import tsx scripts/generate-version.ts && npm run frontend:build",
    "prefrontend:build": "node --import tsx scripts/generate-version.ts",
    "prefrontend:dev": "node --import tsx scripts/generate-version.ts",
    "build": "npm run frontend:build",
    "lint": "eslint . --max-warnings=0 && npm run frontend:lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,md,yml,yaml}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run frontend:check",
    "test": "npm run frontend:build && npm run test:unit && npm run test:integration && npm run test:syntax && npm run test:security && npm run test:smoke",
    "test:unit": "node --import tsx scripts/run-tests.ts tests/services tests/i18n",
    "test:integration": "node --import tsx scripts/run-tests.ts tests/integration",
    "test:syntax": "npm run typecheck",
    "test:security": "node --import tsx scripts/check-csp-security.ts",
    "pretest:e2e": "npm run frontend:build",
    "test:e2e": "playwright test",
    "pretest:smoke": "npm run frontend:build",
    "test:smoke": "node --import tsx scripts/smoke-test.ts",
    "perf:smoke": "node --import tsx scripts/perf-smoke.ts",
    "analyze": "npm --prefix frontend run analyze",
    "depcheck": "depcheck --ignores=\"@eslint/js,globals,eslint-config-prettier,eslint-plugin-svelte,svelte\"",
    "dev": "npm run dev:full",
    "dev:server": "node --import tsx server.sveltekit.ts",
    "dev:full": "npm run frontend:build && node --import tsx server.sveltekit.ts",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "frontend:check": "npm --prefix frontend run check",
    "frontend:lint": "npm --prefix frontend run lint",
    "i18n:extract": "node --import tsx scripts/i18n-extract.ts",
    "i18n:validate": "node --import tsx scripts/i18n-validate.ts",
    "i18n:check": "node --import tsx scripts/i18n-check.ts",
    "start": "node --import tsx server.sveltekit.ts",
    "start:sveltekit": "node --import tsx server.sveltekit.ts",
    "db:seed": "node --import tsx scripts/db-seed.ts",
    "admin:create-master": "node --import tsx scripts/create-master-admin.ts",
    "tiles:build": "node --import tsx scripts/tiles-build.ts",
    "admin:regions:pmtiles": "node --import tsx scripts/build-admin-regions-pmtiles.ts",
    "sync:city": "node --import tsx scripts/sync-osm-buildings.ts",
    "migrate": "node --import tsx scripts/migrate.ts",
    "db:pg:migrate": "node --import tsx scripts/postgres-migrate.ts",
    "db:pg:smoke": "node --import tsx scripts/postgres-smoke.ts",
    "test:integration:postgres": "node --import tsx scripts/run-tests.ts tests/integration/postgres.integration.test.ts tests/integration/postgres-runtime.integration.test.ts",
    "version:print": "node -e \"console.log(JSON.stringify(require('./src/lib/version.generated.json'), null, 2))\""
  },
  "keywords": [],
  "author": "Archimap Contributors",
  "license": "Apache-2.0",
  "description": "Archimap map editing service",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "redis": "^5.8.2",
    "tsx": "^4.21.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^25.5.0",
    "depcheck": "^1.4.7",
    "drizzle-kit": "1.0.0-beta.20",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "svelte": "^5.55.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
