{
  "name": "archimap",
  "version": "1.0.0",
  "main": "server.sveltekit.js",
  "scripts": {
    "predev": "node scripts/generate-version.js",
    "prebuild": "node scripts/generate-version.js",
    "prestart": "node scripts/generate-version.js && npm run frontend:build",
    "prefrontend:build": "node scripts/generate-version.js",
    "prefrontend:dev": "node scripts/generate-version.js",
    "build": "npm run frontend:build",
    "lint": "eslint . --max-warnings=0 && npm run frontend:lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,md,yml,yaml}\"",
    "test": "npm run frontend:build && npm run test:unit && npm run test:integration && npm run test:syntax && npm run test:security && npm run test:smoke",
    "test:unit": "node --test tests/services tests/i18n",
    "test:integration": "node --test tests/integration",
    "test:syntax": "node --check server.js && node --check server.sveltekit.js && node --check src/lib/server/auth/index.js",
    "test:security": "node scripts/check-csp-security.js",
    "pretest:e2e": "npm run frontend:build",
    "test:e2e": "playwright test",
    "pretest:smoke": "npm run frontend:build",
    "test:smoke": "node scripts/smoke-test.js",
    "perf:smoke": "node scripts/perf-smoke.js",
    "analyze": "npm --prefix frontend run analyze",
    "depcheck": "depcheck --ignores=\"@eslint/js,globals,eslint-config-prettier,eslint-plugin-svelte,svelte\"",
    "dev": "npm run dev:full",
    "dev:server": "node server.sveltekit.js",
    "dev:full": "npm run frontend:build && node server.sveltekit.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "frontend:check": "npm --prefix frontend run check",
    "frontend:lint": "npm --prefix frontend run lint",
    "i18n:extract": "node scripts/i18n-extract.js",
    "i18n:validate": "node scripts/i18n-validate.js",
    "i18n:check": "node scripts/i18n-check.js",
    "start": "node server.sveltekit.js",
    "start:sveltekit": "node server.sveltekit.js",
    "db:seed": "node scripts/db-seed.js",
    "admin:create-master": "node scripts/create-master-admin.js",
    "tiles:build": "node scripts/tiles-build.js",
    "admin:regions:pmtiles": "node scripts/build-admin-regions-pmtiles.js",
    "sync:city": "node scripts/sync-osm-buildings.js",
    "migrate": "node scripts/migrate.js",
    "db:pg:migrate": "node scripts/postgres-migrate.js",
    "db:pg:smoke": "node scripts/postgres-smoke.js",
    "test:integration:postgres": "node --test tests/integration/postgres.integration.test.js tests/integration/postgres-runtime.integration.test.js",
    "version:print": "node -e \"console.log(JSON.stringify(require('./src/lib/version.generated.json'), null, 2))\""
  },
  "keywords": [],
  "author": "Archimap Contributors",
  "license": "Apache-2.0",
  "description": "Archimap map editing service",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "redis": "^5.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.54.2",
    "depcheck": "^1.4.7",
    "drizzle-kit": "1.0.0-beta.16-2ffd1a5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "svelte": "^5.20.0"
  }
}
