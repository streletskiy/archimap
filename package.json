{
  "name": "archimap",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "prestart": "npm run frontend:build",
    "build": "npm run frontend:build",
    "lint": "eslint . --max-warnings=0 && npm run frontend:lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,md,yml,yaml}\"",
    "test": "npm run frontend:build && npm run test:unit && npm run test:integration && npm run test:syntax && npm run test:security && npm run test:smoke",
    "test:unit": "node --test tests/services tests/i18n",
    "test:integration": "node --test tests/integration",
    "test:syntax": "node --check server.js && node --check src/lib/server/auth/index.js",
    "test:security": "node scripts/check-csp-security.js",
    "test:e2e": "playwright test",
    "test:smoke": "node scripts/smoke-test.js",
    "depcheck": "depcheck --ignores=\"@eslint/js,globals,eslint-config-prettier,eslint-plugin-svelte,svelte\"",
    "dev": "npm run frontend:build && node server.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "frontend:check": "npm --prefix frontend run check",
    "frontend:lint": "npm --prefix frontend run lint",
    "start": "node server.js",
    "sync:city": "node scripts/sync-osm-buildings.js",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "nodemailer": "^8.0.1",
    "redis": "^5.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.54.2",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "svelte": "^5.20.0"
  }
}
