{
  "name": "archimap-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:bootstrap": "tsc -p ./tsconfig.svelte-config.json && node -e \"const fs=require('fs'); fs.copyFileSync('./build/.bootstrap/svelte.config.js', './svelte.config.js'); fs.rmSync('./build/.bootstrap', { recursive: true, force: true });\" && tsc -p ./tsconfig.theme-init.json && svelte-kit sync",
    "predev": "npm run generate:bootstrap",
    "prebuild": "npm run generate:bootstrap",
    "preanalyze": "npm run generate:bootstrap",
    "prepreview": "npm run generate:bootstrap",
    "precheck": "npm run generate:bootstrap",
    "dev": "vite dev --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "analyze": "vite build --mode analyze",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --ext .ts,.svelte --max-warnings=0"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/adapter-node": "^5.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/types": "^8.57.2",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "csstype": "^3.2.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "archimap": "file:..",
    "maplibre-gl": "5.21.0",
    "marked": "^17.0.5",
    "osmtogeojson": "^3.0.0-beta.5",
    "pmtiles": "^4.4.0",
    "svelte-awesome-color-picker": "^4.1.0"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.9",
    "cookie": "0.7.2"
  }
}
