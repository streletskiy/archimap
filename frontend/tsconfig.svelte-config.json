{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "declaration": false,
    "emitDeclarationOnly": false,
    "rootDir": "./src/bootstrap",
    "outDir": "./build/.bootstrap"
  },
  "include": ["src/bootstrap/svelte.config.ts"]
}
